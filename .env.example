# Credentials template. Copy this file to `.env` and fill in real values.
# `.env` is never committed to git (see .gitignore).

# KRX Data marketplace account (free signup at https://data.krx.co.kr).
# Required by pykrx for authenticated cross-sectional queries.
KRX_ID=your_krx_id
KRX_PW=your_krx_password

# OpenDART API key (https://opendart.fss.or.kr) — used by OpenDartReader
# for the book-equity (BE) loader.
DART_API_KEY=your_dart_api_key

# ECOS (Bank of Korea) API key (https://ecos.bok.or.kr) — used by
# PublicDataReader for the risk-free rate (CD91).
ECOS_API_KEY=your_ecos_api_key
